local CryoLib = {}

local function tableFind(t, val)
    for i, v in next, t do
        if v == val then return i end
    end
    return nil
end

function CryoLib:CreateWindow(title)
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local player = Players.LocalPlayer

    local accentColor = Color3.fromRGB(120, 170, 255)
    local guiKey = "K"

    local windowData = {
        tabs = {},
        toggles = {},
        dropdowns = {},
        keybinds = {},
        visible = true,
        closed = false,
        minimized = false
    }

    local connections = {}
    local function track(conn)
        table.insert(connections, conn)
        return conn
    end

    -- ОЧИСТКА: отключаем все старые соединения при создании нового окна
    -- Это предотвращает дублирование при респавне
    if _G.CryoLibConnections then
        for _, conn in ipairs(_G.CryoLibConnections) do
            if conn then pcall(function() conn:Disconnect() end) end
        end
    end
    _G.CryoLibConnections = connections

    -- ОЧИСТКА: уничтожаем старый GUI если он есть
    if _G.CryoLibScreenGui then
        pcall(function() _G.CryoLibScreenGui:Destroy() end)
    end

    local function closeAllDropdowns()
        for _, dd in ipairs(windowData.dropdowns) do
            if dd.open then dd.close() end
        end
    end

    local function addGlow(frame, color)
        local stroke = Instance.new("UIStroke")
        stroke.Color = color
        stroke.Thickness = 2
        stroke.Transparency = 0.3
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.Parent = frame
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "Hexagon Hub"
    screenGui.ResetOnSpawn = false  -- ВАЖНО: GUI не пересоздаётся при респавне
    screenGui.DisplayOrder = 999
    screenGui.Parent = player:WaitForChild("PlayerGui")
    _G.CryoLibScreenGui = screenGui  -- Сохраняем ссылку для очистки

    local dropdownOverlay = Instance.new("Frame")
    dropdownOverlay.Size = UDim2.new(1, 0, 1, 0)
    dropdownOverlay.BackgroundTransparency = 1
    dropdownOverlay.ZIndex = 1000
    dropdownOverlay.ClipsDescendants = true
    dropdownOverlay.Parent = screenGui

    local floatButton = Instance.new("ImageButton")
    floatButton.Size = UDim2.new(0, 48, 0, 48)
    floatButton.Position = UDim2.new(0, 24, 0.5, -24)
    floatButton.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    floatButton.Image = "rbxassetid://12129379472"
    floatButton.ZIndex = 100
    floatButton.Parent = screenGui
    local floatCorner = Instance.new("UICorner")
    floatCorner.CornerRadius = UDim.new(1, 0)
    floatCorner.Parent = floatButton
    addGlow(floatButton, accentColor)

    local isDragging, dragStart, dragPos
    track(floatButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true; dragStart = input.Position; dragPos = floatButton.Position
        end
    end))
    track(UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            floatButton.Position = UDim2.new(dragPos.X.Scale, dragPos.X.Offset + delta.X, dragPos.Y.Scale, dragPos.Y.Offset + delta.Y)
        end
    end))
    track(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = false end
    end))

    local mainPanel = Instance.new("Frame")
    mainPanel.Size = UDim2.new(0, 440, 0, 540)
    mainPanel.Position = UDim2.new(0.5, -220, 0.5, -270)
    mainPanel.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
    mainPanel.ClipsDescendants = true
    mainPanel.ZIndex = 10
    mainPanel.Parent = screenGui
    local mainCorner = Instance.new("UICorner"); mainCorner.CornerRadius = UDim.new(0, 16); mainCorner.Parent = mainPanel
    addGlow(mainPanel, accentColor)

    local tabPanel = Instance.new("Frame")
    tabPanel.Size = UDim2.new(0, 110, 1, -54)
    tabPanel.Position = UDim2.new(0, 0, 0, 54)
    tabPanel.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    tabPanel.BorderSizePixel = 0; tabPanel.ZIndex = 11; tabPanel.Parent = mainPanel
    local tabCorner = Instance.new("UICorner"); tabCorner.CornerRadius = UDim.new(0, 16); tabCorner.Parent = tabPanel
    local tabPatch = Instance.new("Frame")
    tabPatch.Size = UDim2.new(0.5, 0, 1, 0); tabPatch.Position = UDim2.new(0.5, 0, 0, 0)
    tabPatch.BackgroundColor3 = Color3.fromRGB(15, 15, 20); tabPatch.BorderSizePixel = 0; tabPatch.ZIndex = 11; tabPatch.Parent = tabPanel

    local contentArea = Instance.new("Frame")
    contentArea.Size = UDim2.new(1, -110, 1, -54); contentArea.Position = UDim2.new(0, 110, 0, 54)
    contentArea.BackgroundTransparency = 1; contentArea.ZIndex = 11; contentArea.Parent = mainPanel

    local normalSize = UDim2.new(0, 440, 0, 540)
    local normalPos = UDim2.new(0.5, -220, 0.5, -270)
    local miniSize = UDim2.new(0, 440, 0, 54)

    local function showPanel()
        mainPanel.Visible = true
        TweenService:Create(mainPanel, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = normalSize, Position = normalPos}):Play()
        tabPanel.Visible = true; contentArea.Visible = true; windowData.minimized = false
    end

    local function hidePanel()
        closeAllDropdowns()
        TweenService:Create(mainPanel, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        task.delay(0.3, function() mainPanel.Visible = false; mainPanel.Size = normalSize; mainPanel.Position = normalPos end)
    end

    local function toggleMinimize()
        closeAllDropdowns()
        if windowData.minimized then
            TweenService:Create(mainPanel, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = normalSize}):Play()
            tabPanel.Visible = true; contentArea.Visible = true; windowData.minimized = false
        else
            TweenService:Create(mainPanel, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = miniSize}):Play()
            tabPanel.Visible = false; contentArea.Visible = false; windowData.minimized = true
        end
    end

    local function closePanel()
        if windowData.closed then return end
        windowData.closed = true; closeAllDropdowns()
        for _, toggle in ipairs(windowData.toggles) do
            if toggle.active then
                toggle.active = false; toggle.callback(false)
                if toggle.bg then TweenService:Create(toggle.bg, TweenInfo.new(0.25), {BackgroundColor3 = Color3.fromRGB(50, 50, 65)}):Play() end
                if toggle.knob then TweenService:Create(toggle.knob, TweenInfo.new(0.25), {Position = UDim2.new(0, 2, 0.5, -9)}):Play() end
            end
        end
        TweenService:Create(mainPanel, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        TweenService:Create(floatButton, TweenInfo.new(0.4), {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
        task.delay(0.6, function()
            for _, conn in ipairs(connections) do
                if conn then pcall(function() conn:Disconnect() end) end
            end
            -- Очищаем глобальные ссылки
            _G.CryoLibConnections = nil
            _G.CryoLibScreenGui = nil
            screenGui:Destroy()
        end)
    end

    local function toggleGui()
        windowData.visible = not windowData.visible
        if windowData.visible then showPanel() else hidePanel() end
    end

    floatButton.MouseButton1Click:Connect(toggleGui)

    local guiKeyConnection
    local function setGuiKeybind(key)
        if guiKeyConnection then guiKeyConnection:Disconnect() end
        guiKey = key
        guiKeyConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if not gameProcessed and input.KeyCode == Enum.KeyCode[key] then toggleGui() end
        end)
        track(guiKeyConnection)
    end
    setGuiKeybind("K")

    function windowData:SetGuiKey(key) setGuiKeybind(key) end
    function windowData:GetGuiKey() return guiKey end

    local header = Instance.new("Frame")
    header.Size = UDim2.new(1, 0, 0, 54); header.BackgroundColor3 = Color3.fromRGB(22, 22, 30); header.BorderSizePixel = 0; header.ZIndex = 11; header.Parent = mainPanel
    local headerCorner = Instance.new("UICorner"); headerCorner.CornerRadius = UDim.new(0, 16); headerCorner.Parent = header
    local headerPatch = Instance.new("Frame")
    headerPatch.Size = UDim2.new(1, 0, 0.5, 0); headerPatch.Position = UDim2.new(0, 0, 0.5, 0)
    headerPatch.BackgroundColor3 = Color3.fromRGB(22, 22, 30); headerPatch.BorderSizePixel = 0; headerPatch.ZIndex = 11; headerPatch.Parent = header

    local logo = Instance.new("ImageLabel")
    logo.Size = UDim2.new(0, 30, 0, 30); logo.Position = UDim2.new(0, 16, 0, 12); logo.BackgroundTransparency = 1
    logo.Image = "rbxassetid://119085437225835"; logo.ScaleType = Enum.ScaleType.Fit; logo.ZIndex = 12; logo.Parent = header

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(0, 200, 0, 30); titleLabel.Position = UDim2.new(0, 52, 0, 12); titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title; titleLabel.Font = Enum.Font.GothamBlack; titleLabel.TextSize = 20
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255); titleLabel.TextXAlignment = Enum.TextXAlignment.Left; titleLabel.ZIndex = 12; titleLabel.Parent = header

    local closeButton = Instance.new("TextButton")
    closeButton.Size = UDim2.new(0, 30, 0, 30); closeButton.Position = UDim2.new(1, -40, 0, 12); closeButton.BackgroundTransparency = 1
    closeButton.Text = "x"; closeButton.Font = Enum.Font.GothamBlack; closeButton.TextSize = 24
    closeButton.TextColor3 = Color3.fromRGB(150, 150, 150); closeButton.AutoButtonColor = false; closeButton.ZIndex = 12; closeButton.Parent = header
    closeButton.MouseButton1Click:Connect(closePanel)
    closeButton.MouseEnter:Connect(function() TweenService:Create(closeButton, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(255, 80, 80)}):Play() end)
    closeButton.MouseLeave:Connect(function() TweenService:Create(closeButton, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play() end)

    local minimizeButton = Instance.new("TextButton")
    minimizeButton.Size = UDim2.new(0, 30, 0, 30); minimizeButton.Position = UDim2.new(1, -72, 0, 12); minimizeButton.BackgroundTransparency = 1
    minimizeButton.Text = "-"; minimizeButton.Font = Enum.Font.GothamBlack; minimizeButton.TextSize = 28
    minimizeButton.TextColor3 = Color3.fromRGB(150, 150, 150); minimizeButton.AutoButtonColor = false; minimizeButton.ZIndex = 12; minimizeButton.Parent = header
    minimizeButton.MouseButton1Click:Connect(toggleMinimize)
    minimizeButton.MouseEnter:Connect(function() TweenService:Create(minimizeButton, TweenInfo.new(0.15), {TextColor3 = accentColor}):Play() end)
    minimizeButton.MouseLeave:Connect(function() TweenService:Create(minimizeButton, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(150, 150, 150)}):Play() end)

    local panelDrag, panelDragStart, panelDragPos
    track(header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and not windowData.closed then
            panelDrag = true; panelDragStart = input.Position; panelDragPos = mainPanel.Position
        end
    end))
    track(UserInputService.InputChanged:Connect(function(input)
        if panelDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - panelDragStart
            mainPanel.Position = UDim2.new(panelDragPos.X.Scale, panelDragPos.X.Offset + delta.X, panelDragPos.Y.Scale, panelDragPos.Y.Offset + delta.Y)
            normalPos = mainPanel.Position
        end
    end))
    track(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then panelDrag = false end
    end))

    local tabIndicator = Instance.new("Frame")
    tabIndicator.Size = UDim2.new(0, 3, 0, 0); tabIndicator.Position = UDim2.new(0, 8, 0, 0)
    tabIndicator.BackgroundColor3 = accentColor; tabIndicator.BorderSizePixel = 0; tabIndicator.Visible = false; tabIndicator.ZIndex = 12; tabIndicator.Parent = tabPanel

    track(UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = UserInputService:GetMouseLocation()
            for _, dd in ipairs(windowData.dropdowns) do
                if dd.open and dd.listFrame and dd.buttonFrame then
                    local listPos = dd.listFrame.AbsolutePosition; local listSize = dd.listFrame.AbsoluteSize
                    local btnPos = dd.buttonFrame.AbsolutePosition; local btnSize = dd.buttonFrame.AbsoluteSize
                    local insideList = mousePos.X >= listPos.X and mousePos.X <= listPos.X + listSize.X and mousePos.Y >= listPos.Y and mousePos.Y <= listPos.Y + listSize.Y
                    local insideBtn = mousePos.X >= btnPos.X and mousePos.X <= btnPos.X + btnSize.X and mousePos.Y >= btnPos.Y and mousePos.Y <= btnPos.Y + btnSize.Y
                    if not insideList and not insideBtn then dd.close() end
                end
            end
        end
    end))

    function windowData:CreateTab(name)
        local tab = {}
        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(1, -24, 1, -20); scroll.Position = UDim2.new(0, 12, 0, 10); scroll.Visible = false
        scroll.BackgroundTransparency = 1; scroll.BorderSizePixel = 0; scroll.ScrollBarThickness = 3
        scroll.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 75); scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        scroll.CanvasSize = UDim2.new(0, 0, 0, 0); scroll.ZIndex = 11; scroll.Parent = contentArea
        local listLayout = Instance.new("UIListLayout"); listLayout.Padding = UDim.new(0, 10); listLayout.SortOrder = Enum.SortOrder.LayoutOrder; listLayout.Parent = scroll
        local padding = Instance.new("UIPadding"); padding.PaddingTop = UDim.new(0, 4); padding.PaddingBottom = UDim.new(0, 10); padding.PaddingLeft = UDim.new(0, 4); padding.PaddingRight = UDim.new(0, 4); padding.Parent = scroll

        local tabButton = Instance.new("TextButton")
        tabButton.Size = UDim2.new(1, -16, 0, 38); tabButton.Position = UDim2.new(0, 8, 0, #windowData.tabs * 42 + 12)
        tabButton.Text = name; tabButton.BackgroundTransparency = 1; tabButton.TextColor3 = Color3.fromRGB(130, 130, 145)
        tabButton.Font = Enum.Font.GothamBold; tabButton.TextSize = 13; tabButton.AutoButtonColor = false; tabButton.ZIndex = 12; tabButton.Parent = tabPanel
        local tabBg = Instance.new("Frame")
        tabBg.Size = UDim2.new(1, 0, 1, 0); tabBg.BackgroundColor3 = Color3.fromRGB(25, 25, 35); tabBg.BackgroundTransparency = 1; tabBg.ZIndex = 11; tabBg.Parent = tabButton
        Instance.new("UICorner", tabBg).CornerRadius = UDim.new(0, 8)

        tabButton.MouseButton1Click:Connect(function()
            for _, t in ipairs(windowData.tabs) do
                t.scroll.Visible = false; t.button.TextColor3 = Color3.fromRGB(130, 130, 145)
                TweenService:Create(t.background, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            end
            scroll.Visible = true; tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            TweenService:Create(tabBg, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
            tabIndicator.Visible = true
            TweenService:Create(tabIndicator, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
                Position = UDim2.new(0, 8, 0, tabButton.AbsolutePosition.Y - tabPanel.AbsolutePosition.Y), Size = UDim2.new(0, 3, 0, 38)
            }):Play()
        end)

        table.insert(windowData.tabs, {scroll = scroll, button = tabButton, background = tabBg})

        if #windowData.tabs == 1 then
            scroll.Visible = true; tabButton.TextColor3 = Color3.fromRGB(255, 255, 255); tabBg.BackgroundTransparency = 0
            tabIndicator.Visible = true; tabIndicator.Size = UDim2.new(0, 3, 0, 38)
            tabIndicator.Position = UDim2.new(0, 8, 0, tabButton.AbsolutePosition.Y - tabPanel.AbsolutePosition.Y)
        end

        function tab:CreateToggle(text, callback)
            local active = false
            local frame = Instance.new("Frame"); frame.Size = UDim2.new(1, -4, 0, 48); frame.BackgroundColor3 = Color3.fromRGB(28, 28, 36); frame.BorderSizePixel = 0; frame.ZIndex = 11; frame.Parent = scroll
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
            local label = Instance.new("TextLabel"); label.Size = UDim2.new(1, -70, 1, 0); label.Position = UDim2.new(0, 14, 0, 0); label.Text = text
            label.Font = Enum.Font.GothamBold; label.TextColor3 = Color3.fromRGB(220, 220, 235); label.BackgroundTransparency = 1; label.TextXAlignment = Enum.TextXAlignment.Left; label.TextSize = 14; label.ZIndex = 12; label.Parent = frame
            local bg = Instance.new("Frame"); bg.Size = UDim2.new(0, 40, 0, 22); bg.Position = UDim2.new(1, -52, 0.5, -11); bg.BackgroundColor3 = Color3.fromRGB(50, 50, 65); bg.BorderSizePixel = 0; bg.ZIndex = 12; bg.Parent = frame
            Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
            local knob = Instance.new("Frame"); knob.Size = UDim2.new(0, 18, 0, 18); knob.Position = UDim2.new(0, 2, 0.5, -9); knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); knob.BorderSizePixel = 0; knob.ZIndex = 13; knob.Parent = bg
            Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
            local button = Instance.new("TextButton"); button.Size = UDim2.new(1, 0, 1, 0); button.BackgroundTransparency = 1; button.Text = ""; button.AutoButtonColor = false; button.ZIndex = 14; button.Parent = frame

            local function setState(newState)
                active = newState
                TweenService:Create(bg, TweenInfo.new(0.25), {BackgroundColor3 = active and accentColor or Color3.fromRGB(50, 50, 65)}):Play()
                TweenService:Create(knob, TweenInfo.new(0.25), {Position = active and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)}):Play()
                callback(active)
            end
            button.MouseButton1Click:Connect(function() setState(not active) end)

            local toggleData = {name = text, active = false, callback = callback, bg = bg, knob = knob, set = setState, get = function() return active end}
            table.insert(windowData.toggles, toggleData)
            return {Set = setState, Get = function() return active end}
        end

        function tab:CreateSlider(text, min, max, default, callback)
            local value = default or min
            local frame = Instance.new("Frame"); frame.Size = UDim2.new(1, -4, 0, 68); frame.BackgroundColor3 = Color3.fromRGB(28, 28, 36); frame.BorderSizePixel = 0; frame.ZIndex = 11; frame.Parent = scroll
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
            local label = Instance.new("TextLabel"); label.Size = UDim2.new(1, -24, 0, 22); label.Position = UDim2.new(0, 14, 0, 10); label.BackgroundTransparency = 1
            label.Text = text .. ": " .. value; label.Font = Enum.Font.GothamBold; label.TextSize = 14; label.TextColor3 = Color3.fromRGB(220, 220, 235); label.TextXAlignment = Enum.TextXAlignment.Left; label.ZIndex = 12; label.Parent = frame
            local track = Instance.new("Frame"); track.Size = UDim2.new(1, -36, 0, 6); track.Position = UDim2.new(0, 18, 0, 44); track.BackgroundColor3 = Color3.fromRGB(45, 45, 60); track.BorderSizePixel = 0; track.ZIndex = 12; track.Parent = frame
            Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
            local p = math.clamp((value - min) / (max - min), 0, 1)
            local fill = Instance.new("Frame"); fill.Size = UDim2.new(p, 0, 1, 0); fill.BackgroundColor3 = accentColor; fill.BorderSizePixel = 0; fill.ZIndex = 13; fill.Parent = track
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
            local handle = Instance.new("Frame"); handle.Size = UDim2.new(0, 16, 0, 16); handle.Position = UDim2.new(p, -8, 0.5, -8); handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255); handle.BorderSizePixel = 0; handle.ZIndex = 14; handle.Parent = track
            Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)

            local dragging = false
            local function update()
                local m = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                value = math.floor(min + (m * (max - min)))
                label.Text = text .. ": " .. value; fill.Size = UDim2.new(m, 0, 1, 0); handle.Position = UDim2.new(m, -8, 0.5, -8); callback(value)
            end
            track.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update() end end)
            UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update() end end)
            UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

            local sliderObj = {}
            function sliderObj:Set(newValue)
                newValue = math.clamp(newValue, min, max); value = newValue
                local newP = (value - min) / (max - min)
                label.Text = text .. ": " .. value; fill.Size = UDim2.new(newP, 0, 1, 0); handle.Position = UDim2.new(newP, -8, 0.5, -8); callback(value)
            end
            function sliderObj:Get() return value end
            return sliderObj
        end

        function tab:CreateButton(text, callback)
            local btn = Instance.new("TextButton"); btn.Size = UDim2.new(1, -4, 0, 44); btn.BackgroundColor3 = accentColor; btn.Text = text
            btn.Font = Enum.Font.GothamBlack; btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.TextSize = 14; btn.AutoButtonColor = false; btn.ZIndex = 12; btn.Parent = scroll
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
            btn.MouseButton1Click:Connect(callback)
