        end

        function tab:CreateLabel(text)
            local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(1, 0, 0, 28); lbl.Text = text
            lbl.TextColor3 = accentColor; lbl.Font = Enum.Font.GothamBlack; lbl.BackgroundTransparency = 1; lbl.TextSize = 13; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 12; lbl.Parent = scroll
            return lbl
        end

        function tab:CreateKeybind(text, defaultKey, callback)
            local key = defaultKey or "None"; local binding = false; local hotkeyConn
            local frame = Instance.new("Frame"); frame.Size = UDim2.new(1, -4, 0, 48); frame.BackgroundColor3 = Color3.fromRGB(28, 28, 36); frame.BorderSizePixel = 0; frame.ZIndex = 11; frame.Parent = scroll
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
            local label = Instance.new("TextLabel"); label.Size = UDim2.new(0, 160, 1, 0); label.Position = UDim2.new(0, 14, 0, 0); label.Text = text
            label.Font = Enum.Font.GothamBold; label.TextColor3 = Color3.fromRGB(220, 220, 235); label.BackgroundTransparency = 1; label.TextXAlignment = Enum.TextXAlignment.Left; label.TextSize = 14; label.ZIndex = 12; label.Parent = frame
            local keyButton = Instance.new("TextButton"); keyButton.Size = UDim2.new(0, 60, 0, 28); keyButton.Position = UDim2.new(1, -76, 0.5, -14)
            keyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 55); keyButton.Text = key; keyButton.Font = Enum.Font.GothamBold; keyButton.TextSize = 11
            keyButton.TextColor3 = Color3.fromRGB(255, 255, 255); keyButton.AutoButtonColor = false; keyButton.ZIndex = 12; keyButton.Parent = frame
            Instance.new("UICorner", keyButton).CornerRadius = UDim.new(0, 6)

            local function updateHotkeyConnection()
                if hotkeyConn then hotkeyConn:Disconnect() end
                if key ~= "None" and key ~= "..." then
                    hotkeyConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                        if gameProcessed or binding then return end
                        if input.KeyCode == Enum.KeyCode[key] then callback(key) end
                    end)
                end
            end
            updateHotkeyConnection()

            keyButton.MouseButton1Click:Connect(function() binding = true; keyButton.Text = "..."; keyButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100) end)

            local bindConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if not binding or gameProcessed then return end
                if input.KeyCode == Enum.KeyCode.Escape then binding = false; keyButton.Text = key; keyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 55); return end
                key = input.KeyCode.Name; keyButton.Text = key; binding = false; keyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 55); updateHotkeyConnection()
            end)
            table.insert(windowData.keybinds, bindConn)
            return {GetKey = function() return key end, SetKey = function(k) key = k; keyButton.Text = k; updateHotkeyConnection() end}
        end

        function tab:CreateColorPicker(text, defaultColor, callback)
            local color = defaultColor or Color3.fromRGB(255, 0, 0)
            local r, g, b = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
            local expanded = false; local sliders = {}
            local frame = Instance.new("Frame"); frame.Size = UDim2.new(1, -4, 0, 52); frame.BackgroundColor3 = Color3.fromRGB(28, 28, 36); frame.BorderSizePixel = 0; frame.ZIndex = 11; frame.ClipsDescendants = true; frame.Parent = scroll
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
            local label = Instance.new("TextLabel"); label.Size = UDim2.new(0, 150, 0, 52); label.Position = UDim2.new(0, 14, 0, 0); label.Text = text
            label.Font = Enum.Font.GothamBold; label.TextColor3 = Color3.fromRGB(220, 220, 235); label.BackgroundTransparency = 1; label.TextXAlignment = Enum.TextXAlignment.Left; label.TextSize = 14; label.ZIndex = 12; label.Parent = frame
            local preview = Instance.new("Frame"); preview.Size = UDim2.new(0, 32, 0, 32); preview.Position = UDim2.new(1, -52, 0, 10); preview.BackgroundColor3 = color; preview.BorderSizePixel = 0; preview.ZIndex = 12; preview.Parent = frame
            Instance.new("UICorner", preview).CornerRadius = UDim.new(0, 8)
            local prevStroke = Instance.new("UIStroke"); prevStroke.Color = Color3.fromRGB(80, 80, 95); prevStroke.Thickness = 2; prevStroke.Parent = preview
            local arrow = Instance.new("TextLabel"); arrow.Size = UDim2.new(0, 24, 0, 24); arrow.Position = UDim2.new(1, -24, 0, 14); arrow.BackgroundTransparency = 1
            arrow.Text = "V"; arrow.Font = Enum.Font.GothamBold; arrow.TextSize = 12; arrow.TextColor3 = Color3.fromRGB(150, 150, 165); arrow.ZIndex = 12; arrow.Parent = frame
            local sliderContainer = Instance.new("Frame"); sliderContainer.Size = UDim2.new(1, -28, 0, 120); sliderContainer.Position = UDim2.new(0, 14, 0, 56); sliderContainer.BackgroundTransparency = 1; sliderContainer.ZIndex = 12; sliderContainer.Parent = frame
            local hexLabel = Instance.new("TextLabel"); hexLabel.Size = UDim2.new(0, 80, 0, 20); hexLabel.Position = UDim2.new(0.5, -40, 0, 100); hexLabel.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
            hexLabel.Text = string.format("#%02X%02X%02X", r, g, b); hexLabel.Font = Enum.Font.GothamBold; hexLabel.TextSize = 11; hexLabel.TextColor3 = Color3.fromRGB(200, 200, 200); hexLabel.ZIndex = 13; hexLabel.Parent = sliderContainer
            Instance.new("UICorner", hexLabel).CornerRadius = UDim.new(0, 4)

            local function updateColor()
                color = Color3.fromRGB(r, g, b); preview.BackgroundColor3 = color; hexLabel.Text = string.format("#%02X%02X%02X", r, g, b); callback(color)
            end

            local function makeSlider(y, sliderLabel, sliderColor, value, onChange)
                local track = Instance.new("Frame"); track.Size = UDim2.new(1, -60, 0, 8); track.Position = UDim2.new(0, 50, 0, y); track.BackgroundColor3 = Color3.fromRGB(45, 45, 60); track.BorderSizePixel = 0; track.ZIndex = 13; track.Parent = sliderContainer
                Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
                local fill = Instance.new("Frame"); fill.Size = UDim2.new(value/255, 0, 1, 0); fill.BackgroundColor3 = sliderColor; fill.BorderSizePixel = 0; fill.ZIndex = 14; fill.Parent = track
                Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
                local handle = Instance.new("Frame"); handle.Size = UDim2.new(0, 14, 0, 14); handle.Position = UDim2.new(value/255, -7, 0.5, -7); handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255); handle.BorderSizePixel = 0; handle.ZIndex = 15; handle.Parent = track
                Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)
                local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(0, 40, 0, 16); lbl.Position = UDim2.new(0, 0, 0, y-4); lbl.BackgroundTransparency = 1; lbl.Text = sliderLabel; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 10; lbl.TextColor3 = sliderColor; lbl.ZIndex = 13; lbl.Parent = sliderContainer
                local valLbl = Instance.new("TextLabel"); valLbl.Size = UDim2.new(0, 30, 0, 16); valLbl.Position = UDim2.new(1, -30, 0, y-4); valLbl.BackgroundTransparency = 1; valLbl.Text = tostring(value); valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 10; valLbl.TextColor3 = Color3.fromRGB(180, 180, 180); valLbl.ZIndex = 13; valLbl.Parent = sliderContainer

                local dragging = false
                local function update()
                    local m = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    local val = math.floor(m * 255)
                    fill.Size = UDim2.new(m, 0, 1, 0); handle.Position = UDim2.new(m, -7, 0.5, -7); valLbl.Text = tostring(val); onChange(val); updateColor()
                end
                track.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update() end end)
                UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update() end end)
                UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
                return {Set = function(v) local newM = v/255; fill.Size = UDim2.new(newM, 0, 1, 0); handle.Position = UDim2.new(newM, -7, 0.5, -7); valLbl.Text = tostring(v); onChange(v); updateColor() end}
            end

            table.insert(sliders, makeSlider(0, "R", Color3.fromRGB(255, 60, 60), r, function(v) r = v end))
            table.insert(sliders, makeSlider(28, "G", Color3.fromRGB(60, 255, 60), g, function(v) g = v end))
            table.insert(sliders, makeSlider(56, "B", Color3.fromRGB(60, 120, 255), b, function(v) b = v end))

            local clickArea = Instance.new("TextButton"); clickArea.Size = UDim2.new(1, 0, 0, 52); clickArea.BackgroundTransparency = 1; clickArea.Text = ""; clickArea.ZIndex = 15; clickArea.Parent = frame
            clickArea.MouseButton1Click:Connect(function()
                expanded = not expanded
                if expanded then frame.Size = UDim2.new(1, -4, 0, 180); arrow.Text = "A" else frame.Size = UDim2.new(1, -4, 0, 52); arrow.Text = "V" end
            end)
            return {GetColor = function() return color end, SetColor = function(c) r = math.floor(c.R*255); g = math.floor(c.G*255); b = math.floor(c.B*255); color = c; preview.BackgroundColor3 = c; hexLabel.Text = string.format("#%02X%02X%02X", r, g, b); for i, s in ipairs(sliders) do s.Set(i==1 and r or i==2 and g or b) end end}
        end

        function tab:CreateDropdown(text, options, multi, callback)
            local selected = multi and {} or (options[1] or "")
            local open = false
            local items = {}

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, -4, 0, 48)
            frame.BackgroundColor3 = Color3.fromRGB(28, 28, 36)
            frame.BorderSizePixel = 0
            frame.ZIndex = 11
            frame.Parent = scroll
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, -50, 1, 0)
            label.Position = UDim2.new(0, 14, 0, 0)
            label.Text = text .. ": " .. (multi and "None" or tostring(selected))
            label.Font = Enum.Font.GothamBold
            label.TextColor3 = Color3.fromRGB(220, 220, 235)
            label.BackgroundTransparency = 1
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.TextSize = 14
            label.ZIndex = 12
            label.Parent = frame

            local arrowLabel = Instance.new("TextLabel")
            arrowLabel.Size = UDim2.new(0, 24, 0, 24)
            arrowLabel.Position = UDim2.new(1, -34, 0.5, -12)
            arrowLabel.BackgroundTransparency = 1
            arrowLabel.Text = "▼"
            arrowLabel.Font = Enum.Font.GothamBold
            arrowLabel.TextSize = 12
            arrowLabel.TextColor3 = Color3.fromRGB(150, 150, 165)
            arrowLabel.ZIndex = 12
            arrowLabel.Parent = frame

            local clickBtn = Instance.new("TextButton")
            clickBtn.Size = UDim2.new(1, 0, 1, 0)
            clickBtn.BackgroundTransparency = 1
            clickBtn.Text = ""
            clickBtn.ZIndex = 14
            clickBtn.Parent = frame

            local listFrame = Instance.new("Frame")
            listFrame.Size = UDim2.new(0, 0, 0, 0)
            listFrame.BackgroundColor3 = Color3.fromRGB(32, 32, 42)
            listFrame.BorderSizePixel = 0
            listFrame.ZIndex = 1001
            listFrame.Visible = false
            listFrame.ClipsDescendants = true
            listFrame.Parent = dropdownOverlay
            Instance.new("UICorner", listFrame).CornerRadius = UDim.new(0, 10)

            local listScroll = Instance.new("ScrollingFrame")
            listScroll.Size = UDim2.new(1, -8, 1, -8)
            listScroll.Position = UDim2.new(0, 4, 0, 4)
            listScroll.BackgroundTransparency = 1
            listScroll.BorderSizePixel = 0
            listScroll.ScrollBarThickness = 2
            listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
            listScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
            listScroll.ZIndex = 1002
            listScroll.Parent = listFrame

            local listLayout = Instance.new("UIListLayout")
            listLayout.Padding = UDim.new(0, 2)
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Parent = listScroll

            local listPadding = Instance.new("UIPadding")
            listPadding.PaddingTop = UDim.new(0, 2)
            listPadding.PaddingBottom = UDim.new(0, 2)
            listPadding.Parent = listScroll

            local currentWidth = 0
            local currentHeight = 0

            local function updateLabel()
                if multi then
                    local n = #selected
                    label.Text = text .. ": " .. (n == 0 and "None" or n == 1 and selected[1] or n .. " selected")
                else
                    label.Text = text .. ": " .. tostring(selected)
                end
            end

            local function updateItems()
                for _, item in ipairs(items) do
                    local isSelected = multi and tableFind(selected, item.option) ~= nil or selected == item.option
                    item.indicator.BackgroundColor3 = isSelected and accentColor or Color3.fromRGB(50, 50, 65)
                    for _, child in ipairs(item.indicator:GetChildren()) do
                        if child:IsA("TextLabel") then child:Destroy() end
                    end
                    if multi and isSelected then
                        local check = Instance.new("TextLabel")
                        check.Size = UDim2.new(1, 0, 1, 0)
                        check.BackgroundTransparency = 1
                        check.Text = "✓"
                        check.Font = Enum.Font.GothamBold
                        check.TextSize = 10
                        check.TextColor3 = Color3.fromRGB(255, 255, 255)
                        check.ZIndex = 1005
                        check.Parent = item.indicator
                    end
                end
            end

            local function makeItem(option)
                local itemBtn = Instance.new("TextButton")
                itemBtn.Size = UDim2.new(1, 0, 0, 32)
                itemBtn.BackgroundTransparency = 1
                itemBtn.Text = "  " .. option
                itemBtn.Font = Enum.Font.GothamBold
                itemBtn.TextSize = 13
                itemBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
                itemBtn.TextXAlignment = Enum.TextXAlignment.Left
                itemBtn.ZIndex = 1003
                itemBtn.Parent = listScroll

                local indicator = Instance.new("Frame")
                indicator.Size = UDim2.new(0, 16, 0, 16)
                indicator.Position = UDim2.new(1, -24, 0.5, -8)
                indicator.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
                indicator.BorderSizePixel = 0
                indicator.ZIndex = 1004
                indicator.Parent = itemBtn
                Instance.new("UICorner", indicator).CornerRadius = UDim.new(multi and 0 or 1, multi and 3 or 0)

                itemBtn.MouseButton1Click:Connect(function()
                    if multi then
                        local found = tableFind(selected, option)
                        if found then table.remove(selected, found) else table.insert(selected, option) end
                        updateItems()
                        callback(selected)
                    else
                        selected = option
                        updateItems()
                        callback(selected)
                        open = false
                        arrowLabel.Text = "▼"
                        TweenService:Create(listFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                            Size = UDim2.new(0, currentWidth, 0, 0)
                        }):Play()
                        task.delay(0.15, function()
                            listFrame.Visible = false
                        end)
                    end
                    updateLabel()
                end)

                table.insert(items, {button = itemBtn, indicator = indicator, option = option})
            end

            for _, option in ipairs(options) do
                makeItem(option)
            end

            local maxHeight = math.min(#options * 34 + 4, 160)

            local function positionList()
                local absPos = frame.AbsolutePosition
                local absSize = frame.AbsoluteSize
                local screenSize = workspace.CurrentCamera.ViewportSize

                local yPos = absPos.Y + absSize.Y + 2
                currentHeight = maxHeight

                if yPos + currentHeight > screenSize.Y - 10 then
                    yPos = absPos.Y - currentHeight - 2
                    if yPos < 10 then
                        yPos = 10
                        currentHeight = absPos.Y - 14
                    end
                end

                local xPos = absPos.X
                currentWidth = absSize.X
                if xPos + currentWidth > screenSize.X - 10 then
                    xPos = screenSize.X - currentWidth - 10
                end
                if xPos < 10 then
                    xPos = 10
                    currentWidth = math.min(currentWidth, screenSize.X - 20)
                end

                listFrame.Position = UDim2.new(0, xPos, 0, yPos)
            end

            local function closeDropdown()
                open = false
                arrowLabel.Text = "▼"
                TweenService:Create(listFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, currentWidth, 0, 0)
                }):Play()
                task.delay(0.15, function()
                    listFrame.Visible = false
                end)
            end

            local function openDropdown()
                open = true
                arrowLabel.Text = "▲"
                positionList()
                listFrame.Visible = true
                updateItems()
                listFrame.Size = UDim2.new(0, currentWidth, 0, 0)
                TweenService:Create(listFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, currentWidth, 0, currentHeight)
                }):Play()
            end

            clickBtn.MouseButton1Click:Connect(function()
                if open then closeDropdown() else openDropdown() end
            end)

            local posConn = RunService.RenderStepped:Connect(function()
                if open then 
                    positionList() 
                    if frame.AbsolutePosition.Y + frame.AbsoluteSize.Y < scroll.AbsolutePosition.Y or 
                       frame.AbsolutePosition.Y > scroll.AbsolutePosition.Y + scroll.AbsoluteSize.Y then
                        closeDropdown()
                    end
                end
            end)
            table.insert(connections, posConn)

            local scrollConn = scroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
                if open then
                    closeDropdown()
                end
            end)
            table.insert(connections, scrollConn)

            local dropdownData = {
                open = false,
                listFrame = listFrame,
                buttonFrame = frame,
                close = closeDropdown
            }
            table.insert(windowData.dropdowns, dropdownData)

            return {
                GetSelected = function() return multi and selected or selected end,
                SetSelected = function(val)
                    if multi then selected = type(val) == "table" and val or {val} else selected = val end
                    updateLabel()
                    updateItems()
                end
            }
        end

        return tab
    end

    function windowData:GetToggle(name)
        for _, t in ipairs(windowData.toggles) do if t.name == name then return t end end
        return nil
    end

    return windowData
end

return CryoLib
